# VPS profile for PUB OASIS SCRIPTORIUM on Debian 13.
# Canonical host layout:
#   - repo:  /opt/oasis-scriptorium
#   - state: /srv/oasis/oasis-pub

OASIS_PUB_HOST=pub.escrivivir.co
OASIS_PUB_WEB_HOST=pub.escrivivir.co

# Public SSB port.
OASIS_PUB_SSB_PORT=8008
OASIS_PUB_INTERNAL_SSB_PORT=8008
OASIS_PUB_SSB_CONFIG_FILE=./config/ssb/config
OASIS_PUB_SSB_DATA_DIR=/srv/oasis/oasis-pub/ssb-data
OASIS_PUB_LOGS_DIR=/srv/oasis/oasis-pub/logs
OASIS_PUB_CADDY_DATA_DIR=/srv/oasis/oasis-pub/caddy-data
OASIS_PUB_CADDY_CONFIG_DIR=/srv/oasis/oasis-pub/caddy-config

# Public web ports.
OASIS_PUB_HTTP_PORT=80
OASIS_PUB_HTTPS_PORT=443

# Local-only admin API port. Access via SSH/VS Code port forwarding.
PUB_PANEL_PORT=8787

# REQUIRED: replace before deploy.
PUB_PANEL_TOKEN=change-me-before-deploy

# Optional frontend integration.
PUB_FRONTEND_DIR=./frontend
PUB_FRONTEND_DOCKERFILE=Dockerfile
PUB_FRONTEND_PORT=8080

# Optional: existing Oasis client URL used by helper scripts.
OASIS_CLIENT_URL=http://localhost:3000
