# Local testing profile for PUB OASIS SCRIPTORIUM
# Safe defaults to avoid clashing with the main Oasis Docker stack.

OASIS_PUB_HOST=localhost
OASIS_PUB_WEB_HOST=http://localhost

# Use 8009 locally so it does not collide with oasis-dev on 8008.
OASIS_PUB_SSB_PORT=8009
OASIS_PUB_INTERNAL_SSB_PORT=8009
OASIS_PUB_SSB_CONFIG_FILE=./config/ssb/config.local
OASIS_PUB_SSB_DATA_DIR=../volumes-dev/oasis-pub/ssb-data
OASIS_PUB_LOGS_DIR=../volumes-dev/oasis-pub/logs
OASIS_PUB_CADDY_DATA_DIR=../volumes-dev/oasis-pub/caddy-data
OASIS_PUB_CADDY_CONFIG_DIR=../volumes-dev/oasis-pub/caddy-config

# Local web ports.
OASIS_PUB_HTTP_PORT=8088
OASIS_PUB_HTTPS_PORT=8443

# Local panel API port.
PUB_PANEL_PORT=8788

# Local-only token. Fine for tests, not for production.
PUB_PANEL_TOKEN=local-dev-token-only-for-local-testing

# Optional frontend integration.
PUB_FRONTEND_DIR=./frontend
PUB_FRONTEND_DOCKERFILE=Dockerfile
PUB_FRONTEND_PORT=8080

# Existing local Oasis client to auto-accept invites.
OASIS_CLIENT_URL=http://localhost:3000
