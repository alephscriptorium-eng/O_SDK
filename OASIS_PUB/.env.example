# PUB OASIS SCRIPTORIUM deployment variables

# Public DNS name for the SSB pub and landing web.
OASIS_PUB_HOST=pub.escrivivir.co
OASIS_PUB_WEB_HOST=pub.escrivivir.co

# Public SSB port. Keep 8008 unless you know why you need another one.
OASIS_PUB_SSB_PORT=8008
OASIS_PUB_INTERNAL_SSB_PORT=8008
OASIS_PUB_SSB_CONFIG_FILE=./config/ssb/config
OASIS_PUB_SSB_DATA_DIR=../volumes-dev/oasis-pub/ssb-data
OASIS_PUB_LOGS_DIR=../volumes-dev/oasis-pub/logs
OASIS_PUB_CADDY_DATA_DIR=../volumes-dev/oasis-pub/caddy-data
OASIS_PUB_CADDY_CONFIG_DIR=../volumes-dev/oasis-pub/caddy-config

# Public web ports. Keep defaults on the VPS.
OASIS_PUB_HTTP_PORT=80
OASIS_PUB_HTTPS_PORT=443

# Local-only admin API port on the VPS. Access via SSH/VS Code port forwarding.
PUB_PANEL_PORT=8787

# REQUIRED: replace before deploy. Example: openssl rand -hex 32
PUB_PANEL_TOKEN=change-me-before-deploy

# Optional Angular/Node frontend integration.
PUB_FRONTEND_DIR=./frontend
PUB_FRONTEND_DOCKERFILE=Dockerfile
PUB_FRONTEND_PORT=8080

# Optional: existing local/client Oasis URL used by join-client helper.
OASIS_CLIENT_URL=http://localhost:3000
