{$OASIS_PUB_WEB_HOST:pub.escrivivir.co} {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
  }

  @public path /public/*
  handle @public {
    reverse_proxy pub-panel-api:8787
  }

  handle {
    root * /srv/site
    try_files {path} {path}/index.html /index.html
    file_server
  }
}

# Scriptorium VPS — hosts aditivos del MVP.
# Edge productivo compartido: este Caddy `pub-web` de OASIS_PUB.
# Upstreams esperados en la red Docker `oasis_pub_net` con aliases `scriptorium-*`.

scriptorium.escrivivir.co {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  @health path /healthz
  handle @health {
    respond "scriptorium public edge ok" 200
  }

  reverse_proxy scriptorium-nodered:1880
}

admin.scriptorium.escrivivir.co {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    X-Robots-Tag noindex, nofollow, noarchive
  }

  @health path /healthz
  handle @health {
    respond "scriptorium admin edge ok" 200
  }

  reverse_proxy scriptorium-nodered:1880
}

